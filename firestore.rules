rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Game rooms are intentionally public (unauthenticated players join via QR)
    match /gameRooms/{roomCode} {
      allow read, write: if true;
    }
    // All other collections require Firebase Auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
